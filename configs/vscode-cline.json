{
  "_comment": "Config for Cline (VS Code extension). Add to Cline MCP Servers settings. Update 'cwd' to the absolute path where you cloned the repo.",
  "mcpServers": {
    "rust-oxide-dev": {
      "command": "node",
      "args": ["dist/index.mjs"],
      "cwd": "/absolute/path/to/mcp_rust_game_dev/mcp-server",
      "env": {
        "RUST_RCON_HOST": "127.0.0.1",
        "RUST_RCON_PORT": "28016",
        "RUST_RCON_PASSWORD": "CHANGE_ME",
        "RUST_SERVER_PATH": "C:/RustServer",
        "RUST_DEPLOY_MODE": "local"
      }
    }
  }
}
